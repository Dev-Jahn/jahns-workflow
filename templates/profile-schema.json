{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "waystone-profile-1",
  "type": "object",
  "required": ["schema", "bindings"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "waystone-profile-1"},
    "bindings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "main": {"$ref": "#/$defs/main"},
        "orchestrator": {"$ref": "#/$defs/orchestrator"},
        "implementer": {"$ref": "#/$defs/worker"},
        "clerk": {"$ref": "#/$defs/worker"},
        "verifier": {"$ref": "#/$defs/independent"},
        "reviewer": {"$ref": "#/$defs/independent"}
      }
    }
  },
  "$defs": {
    "binding": {
      "type": "object",
      "required": ["execution", "backend"],
      "additionalProperties": false,
      "properties": {
        "execution": {
          "enum": [
            "main-session",
            "clean-subagent",
            "forked-subagent",
            "deterministic-workflow",
            "external-runner"
          ]
        },
        "backend": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*:[^\\s:]+$"
        },
        "use_for": {"type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$"},
        "effort": {"enum": ["none", "minimal", "low", "medium", "high", "xhigh"]},
        "entry": {"type": "string"}
      }
    },
    "main": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"properties": {"execution": {"const": "main-session"}}}
      ]
    },
    "orchestrator": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"properties": {"execution": {"enum": [
          "main-session", "clean-subagent", "forked-subagent", "deterministic-workflow"
        ]}}}
      ]
    },
    "worker": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"properties": {"execution": {"enum": [
          "clean-subagent", "forked-subagent", "deterministic-workflow", "external-runner"
        ]}}}
      ]
    },
    "independent": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"properties": {"execution": {"enum": [
          "clean-subagent", "deterministic-workflow", "external-runner"
        ]}}}
      ]
    }
  }
}
